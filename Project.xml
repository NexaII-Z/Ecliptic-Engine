<?xml version="1.0" encoding="utf-8"?>
<project>

	<meta title="Ecliptic Engine" package="com.nexaii.ecliptic" version="0.1.0" company="NexaII-Z" />

	<!-- Libraries -->
	<haxelib name="openfl" />
	<haxelib name="flixel" />
	<haxelib name="flixel-addons" />
	<haxelib name="flixel-ui" />
	<haxelib name="hscript" />

	<!-- Source -->
	<source path="source" />

	<!-- Assets — exclude fonts and audio by platform, then re-add fonts as raw -->
	<assets path="assets" rename="assets" exclude="*.ogg,*.ttf,*.otf" if="html5" />
	<assets path="assets" rename="assets" exclude="*.mp3,*.ttf,*.otf" unless="html5" />

	<!-- Re-add fonts as plain file assets (skips Lime's broken woff converter) -->
	<assets path="assets/Mains/fonts/vcr.ttf"         rename="assets/Mains/fonts/vcr.ttf"         type="binary" />
	<assets path="assets/Mains/fonts/pixel-latin.ttf"  rename="assets/Mains/fonts/pixel-latin.ttf"  type="binary" />

	<!-- Window -->
	<window width="1280" height="720" fps="60" background="#000000" hardware="true" vsync="false" />
	<window resizable="true"   unless="mobile" />
	<window fullscreen="false" unless="mobile" />

	<!-- Defines -->
	<define name="mobile" if="android" />
	<define name="mobile" if="ios" />

	<!-- Optimization -->
	<haxedefine name="no-traces" unless="debug" />

	<!-- Android -->
	<android target-sdk-version="33" if="android" />
	<config:android install-location="preferExternal" if="android" />

</project>
